// Create a point geometry
var NewYorkGeometry = ee.Geometry.Point([-74.0060, 40.7128]);
// Create a circular buffer around the point (radius in meters)
var bufferRadiusNY = 10000;
var NewYorkBuffer = NewYorkGeometry.buffer(bufferRadiusNY);
// Create a FeatureCollection from the buffer
var NewYorkGeometryCollection = ee.FeatureCollection([NewYorkBuffer]);
print(NewYorkGeometryCollection);
Map.centerObject(NewYorkGeometryCollection);
Map.addLayer(NewYorkGeometryCollection);
// Define the date range
var startDateNY = '2022-06-01';
var endDateNY = '2022-11-20';
// Use the NO2 ImageCollection
var datasetNY = ee.ImageCollection("COPERNICUS/S5P/OFFL/L3_NO2")
  .filterBounds(NewYorkGeometry)
  .filter(ee.Filter.date(startDateNY, endDateNY));
// Select the desired band
var desiredBandNY = 'NO2_column_number_density';
// Map a function to set properties for each image
var NO2NY = datasetNY.map(function(image) {
  var date = ee.Date(image.get('system:time_start'));
  var formattedDate = date.format('YYYY-MM-dd');
  return image.set({
    'system:time_start': date,
  'date': formattedDate
  });
});
// Extract the relevant information for export
var exportDataNY = NO2NY.map(function(image) {
  var no2ValueNY = image.reduceRegion({
  reducer: ee.Reducer.mean(),
  geometry: NewYorkBuffer,
  scale: 30,
  }).get(desiredBandNY);
  return ee.Feature(null, {
    'date': image.get('date'),
    'NO2_value': no2ValueNY,
  });
});

// Convert the exportDataNY to a FeatureCollection
var exportFeaturesNY = ee.FeatureCollection(exportDataNY);
// Filter out features with null or undefined values
var filteredExportFeaturesNY = exportFeaturesNY.filter(ee.Filter.notNull(['date','NO2_value']));
// Print the exportFeaturesNY to verify before export
print("Filtered Export Features New York:", filteredExportFeaturesNY);
// Create and print the chart.
print(ui.Chart.image.series({
  imageCollection: NO2NY.select(desiredBandNY),
  region: NewYorkBuffer,
  reducer: ee.Reducer.mean(),
  scale: 30,
  xProperty: 'date'
}));
// Export the data to Google Drive as a CSV file
Export.table.toDrive({
  collection: filteredExportFeaturesNY,
  description: 'Daily_NO2_NewYork',
  fileFormat: 'CSV',
  selectors: ['date', 'NO2_value'],
});
